# ═══ REQUIRED ═══
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/slis_gms
SESSION_SECRET=change-me-to-a-random-64-character-string

# ═══ TESTS ═══
# Point vitest at a real Postgres instance instead of the embedded binary.
# Required on Windows (embedded-postgres cannot bind localhost). Tests will
# DROP/CREATE the public schema in this DB — point it at a dedicated test DB,
# never at your dev DATABASE_URL.
#   Create the DB once:  createdb slis_gms_test   (or via pgAdmin)
#   Then:                TEST_DATABASE_URL=... npm test
# TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/slis_gms_test

# ═══ APP CONFIG ═══
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000

# ═══ OPTIONAL — AI Integration ═══
# OpenAI-compatible API. When the key is set the following endpoints call the
# live model; when unset they fall back to deterministic stub responses:
#   POST /api/ai/repair-guide      (AR Repair Guide page)
#   GET  /api/ai/insights          (AI Insights page)
#   GET  /api/ai/forecast/{revenue,demand}
#   POST /api/ai/recommend-parts   (Smart Parts Recommender)
# Statistical endpoints (/api/ai/predictions, /api/ai/accuracy,
# /api/forecasting/demand, /api/analytics/performance, /api/productivity)
# do NOT need this key — they aggregate from your DB directly.
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
# AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
# OPENAI_API_KEY=sk-...

# ═══ OPTIONAL — Payment gateways (Saudi-first, multi-provider) ═══
# The unified payment layer offers every method whose gateway has keys set.
# With NONE set, only manual (cash / bank transfer / cheque) is available.
# When more than one card/Mada aggregator is configured, PAYMENT_GATEWAY_PRIORITY
# decides which one wins.
# PAYMENT_DEFAULT_CURRENCY=SAR
# PAYMENT_GATEWAY_PRIORITY=moyasar,hyperpay,tap,stripe
# PUBLIC_APP_URL=https://app.salisauto.com   # used to build return/webhook URLs
#
# -- Mada / Visa / Mastercard / Apple Pay / STC Pay (choose one or more) --
# Moyasar (Saudi):
# MOYASAR_SECRET_KEY=sk_...
# MOYASAR_WEBHOOK_SECRET=...
# HyperPay (MENA):
# HYPERPAY_ACCESS_TOKEN=...
# HYPERPAY_ENTITY_ID=...
# HYPERPAY_BASE_URL=https://eu-test.oppwa.com   # live: https://oppwa.com
# Tap Payments (MENA):
# TAP_SECRET_KEY=sk_test_...
#
# -- Buy Now Pay Later --
# Tabby:
# TABBY_SECRET_KEY=sk_...
# TABBY_MERCHANT_CODE=...
# Tamara:
# TAMARA_API_TOKEN=...
# TAMARA_API_URL=https://api-sandbox.tamara.co   # live: https://api.tamara.co
# TAMARA_NOTIFICATION_TOKEN=...
#
# -- Cards (international) --
# Stripe:
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# PayPal:
# PAYPAL_CLIENT_ID=...
# PAYPAL_CLIENT_SECRET=...
# PAYPAL_MODE=sandbox   # or: live

# ═══ OPTIONAL — SMS / WhatsApp ═══
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+966...

# ═══ OPTIONAL — Email Marketing ═══
# GETRESPONSE_API_KEY=...

# ═══ OPTIONAL — Auto Parts Catalog ═══
# TECDOC_API_URL=https://webservice.tecalliance.services/pegasus-3-0/services/TecdocToCatDLB.jsonEndpoint
# TECDOC_API_KEY=...

# ═══ OPTIONAL — Saudi Tax (ZATCA) ═══
# ZATCA_API_URL=https://gw-fatoora.zatca.gov.sa/e-invoicing/developer-portal
# ZATCA_CSID=...

# ═══ OPTIONAL — Cache / Queues ═══
# Redis URL used by the rate-limit and (planned) job-queue layers. If unset
# the app falls back to in-memory rate limiting (single-process only) and
# disables persistent queues. Set this in production for multi-process safety.
# REDIS_URL=redis://localhost:6379

# ═══ OPTIONAL — Backups ═══
# The workflow engine schedules a daily pg_dump (gzipped) into BACKUP_DIR.
# Disabled by default to keep dev runs quiet — set BACKUP_ENABLED=true in prod.
# BACKUP_ENABLED=true
# BACKUP_HOUR_UTC=2
# BACKUP_DIR=/var/backups/gms
# Optional S3 upload via AWS CLI; leave unset for local-only backups:
# AWS_S3_BUCKET=gms-backups-bucket-name
# Retention: how many of each cohort to keep.
# BACKUP_RETAIN_DAILY=30
# BACKUP_RETAIN_WEEKLY=12
# BACKUP_RETAIN_MONTHLY=12

# ═══ OPTIONAL — Stripe Billing ═══
# Set these to enable Stripe Checkout for plan upgrades. Without them the
# /api/subscriptions/change-plan endpoint will fall back to a direct DB
# upgrade (dev-only path). STRIPE_WEBHOOK_SECRET is required to verify
# checkout.session.completed events; obtain it from `stripe listen` in dev
# or the Stripe dashboard for production.
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ENTERPRISE=price_...
